@Post("v1/autenticacion/logout")
funLogout(@Response({ passthrough: true }) res: ExpressResponse) {
  res.clearCookie('access_token', { path: '/' });
  res.clearCookie('refresh_token', { path: '/v1/autenticacion/refresh' });
  return { ok: true };
}
